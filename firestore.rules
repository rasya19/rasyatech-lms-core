rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // School validation helper
    function isValidSchool(data) {
      return data.keys().hasAll(['ownerUid', 'name', 'slug', 'adminEmail', 'adminName', 'whatsapp', 'packageId', 'status', 'createdAt']) &&
             data.ownerUid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 100 &&
             data.adminEmail is string && data.adminEmail.size() >= 3 &&
             data.adminName is string && data.adminName.size() > 0 &&
             data.whatsapp is string && data.whatsapp.size() >= 4 &&
             data.packageId in ['basic', 'pro', 'enterprise'] &&
             data.status in ['pending', 'active'] &&
             data.createdAt == request.time &&
             (!('npsn' in data) || data.npsn is string) &&
             (!('accreditation' in data) || data.accreditation is string) &&
             (!('address' in data) || data.address is string) &&
             (!('paymentMethod' in data) || data.paymentMethod is string);
    }

    match /schools/{schoolId} {
      allow get: if true;
      allow list: if request.auth.token.email.lower() == 'ismanto095@gmail.com';
      allow create: if isValidId(schoolId) && 
                      request.auth.uid == request.resource.data.ownerUid && 
                      !exists(/databases/$(database)/documents/schools/$(schoolId)) &&
                      isValidSchool(request.resource.data);
      allow update: if request.auth.token.email.lower() == 'ismanto095@gmail.com' || (request.auth.uid == resource.data.ownerUid);
      allow delete: if request.auth.token.email.lower() == 'ismanto095@gmail.com';
    }

    match /settings/{settingId} {
      allow get: if true;
      allow write: if request.auth.token.email.lower() == 'ismanto095@gmail.com';
    }

    match /payments/{paymentId} {
      allow read, write: if request.auth.token.email.lower() == 'ismanto095@gmail.com';
    }

    match /affiliates/{id} {
      allow read: if true;
      allow write: if request.auth.token.email.lower() == 'ismanto095@gmail.com';
    }

    match /commissions/{id} {
      allow read: if true;
      allow write: if request.auth.token.email.lower() == 'ismanto095@gmail.com';
    }
  }
}
